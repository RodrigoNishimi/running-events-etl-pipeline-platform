# Conexao com o Postgres (com PostGIS habilitado)
DATABASE_URL=postgresql://corridas:corridas@localhost:5432/corridas

# Diretorio da camada Bronze (raw). Na Fase 1+ trocar por s3://bucket/...
RAW_STORAGE_DIR=./data/raw

# User-Agent honesto usado nas requisicoes de scraping.
# Identifique seu bot e ofereca um canal de contato (boa pratica e defesa legal).
ETL_USER_AGENT=CorridasBot/0.1 (+https://seusite.com.br/bot)

# Intervalo minimo entre requisicoes a uma mesma fonte, em segundos (rate limit).
ETL_REQUEST_DELAY_SECONDS=2.0
